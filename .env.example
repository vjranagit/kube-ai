# .env.example — environment variable overrides for kube-ai config.
# These are applied ON TOP of config.yaml at import time.
# Copy to .env and source before starting the process.

# Control loop
TUNE_MODE=both
CONTROLLER_INTERVAL_SEC=30
CONTROLLER_COOLDOWN_SEC=60
CONTROLLER_PARAM_COOLDOWN_SEC=300
CONTROLLER_DRY_RUN=true

# Replica bounds
MIN_REPLICAS=1
MAX_REPLICAS=8

# max-num-seqs bounds
MIN_MAX_NUM_SEQS=128
MAX_MAX_NUM_SEQS=2048

# Saturation thresholds
PRESSURE_HIGH=0.75
PRESSURE_LOW=0.35

# Latency SLO
TTFT_SLO_SEC=2.0

# Deployment target
VLLM_DEPLOYMENT=vllm-server
VLLM_NAMESPACE=default

# vLLM metrics
VLLM_MODE=mock
VLLM_METRICS_URL=http://vllm-service:8000/metrics

# kubectl execution
EXEC_MODE=local
KUBECTL_CONTEXT=
KUBECTL_NAMESPACE=default
# SSH mode
SSH_HOST=
SSH_USER=
SSH_KEY_FILE=
# Docker mode
DOCKER_CONTAINER=

# Tuner
TUNER_KIND=aimd

# Observability
METRICS_PORT=9108
